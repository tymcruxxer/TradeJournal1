# ============================================
# Trading Journal Backend — Configuration
# ============================================
# Copy this file to .env and adjust values.
#   cp .env.example .env

# ---------- Database ----------
# SQLite (local development):
DATABASE_URL=sqlite:///./trades.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/trading_journal

# ---------- JWT ----------
JWT_SECRET_KEY=change-this-dev-secret-before-deployment
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---------- CORS ----------
# Comma-separated list of allowed origins.
# For local dev frontend (Vite default):
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# For production with custom domain:
# CORS_ORIGINS=https://app.tradingjournal.com

# ---------- Server ----------
HOST=0.0.0.0
PORT=8000