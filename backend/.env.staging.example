# Trading Journal Backend - Staging Environment
#
# Copy these values into your staging host's environment variable settings.
# Do not commit real secrets.

APP_ENV=staging

# Managed PostgreSQL connection string.
# Use the exact URL from your provider, usually with sslmode=require.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# Generate a strong 32+ character random secret.
JWT_SECRET_KEY=replace-with-a-strong-random-staging-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Restrict this to the staging frontend origin.
CORS_ORIGINS=https://staging.tradingjournal.example

HOST=0.0.0.0
PORT=8000
