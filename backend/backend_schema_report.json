  "trade_table_sql": [
    "CREATE TABLE trades (\n\tid INTEGER NOT NULL, \n\tsymbol VARCHAR, \n\tprofit FLOAT, \n\tvolume FLOAT, \n\tentry_price FLOAT, \n\texit_price FLOAT, \n\topen_time DATETIME, \n\tclose_time DATETIME, \n\tduration INTEGER, \n\tstrategy VARCHAR, \n\tnotes VARCHAR, \n\temotion VARCHAR, \n\tticket BIGINT, \n\ttrade_type VARCHAR, \n\ttime DATETIME, user_id INTEGER, account_id VARCHAR, account_name VARCHAR, \n\tPRIMARY KEY (id)\n)"
